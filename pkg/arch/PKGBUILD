# Maintainer: Dmitry Yarikov <dmitry@yarikov.com>
pkgname=kvn-tui
pkgver=0.9.0
pkgrel=1
pkgdesc="Terminal VPN client for Arch Linux + Wayland with vim navigation"
arch=('x86_64')
url="https://github.com/yarikov/kvn-tui"
license=('MIT')
depends=('gcc-libs' 'dbus' 'sing-box')
makedepends=('cargo' 'rust')
# sing-box >= 1.12 required for valid config generation
source=()
options=('!lto')
sha256sums=()

build() {
    cd "$startdir/../../"
    cargo build --release --locked
}

package() {
    cd "$startdir/../../"
    install -Dm755 "target/release/$pkgname" "$pkgdir/usr/bin/$pkgname"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 "contrib/kvn-tui.desktop" "$pkgdir/usr/share/applications/kvn-tui.desktop"
}
